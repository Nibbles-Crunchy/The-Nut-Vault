<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <title>The Nut Vault | Tactical Burrow</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🐹</text></svg>">
    <style>
        :root { --p: #ffcc33; --s: #8b4513; --a: #ff4757; --bg: #1a1a1a; --gold: #ffd700; --grass: #2d5a27; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: #fff; margin: 0; display: flex; flex-direction: column; align-items: center; overflow-x: hidden; }
        #auth-overlay { position: fixed; inset: 0; background: var(--p); display: flex; align-items: center; justify-content: center; z-index: 2000; transition: 0.5s; }
        .login-card { background: #fff; color: var(--s); padding: 2rem; border-radius: 40px; border: 8px solid var(--s); text-align: center; }
        #game-over { position: fixed; inset: 0; background: #000; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 3000; opacity: 0; pointer-events: none; transition: 0.5s; }
        #game-over.active { opacity: 1; pointer-events: auto; }
        header { width: 100%; background: var(--s); color: var(--p); padding: 1rem; display: flex; justify-content: space-around; border-bottom: 5px solid var(--p); position: sticky; top: 0; z-index: 1000; box-sizing: border-box; }
        .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; padding: 20px; width: 95%; max-width: 1300px; }
        .card { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 20px; border: 2px solid var(--p); text-align: center; }
        #game { border: 8px solid #333; border-radius: 15px; background: var(--grass); cursor: crosshair; }
        .inv-slot { display: inline-block; padding: 10px; border: 3px solid #555; border-radius: 12px; margin: 5px; cursor: pointer; background: rgba(0,0,0,0.3); font-size: 1.5rem; }
        .inv-slot.selected { border-color: var(--gold); background: rgba(255,204,51,0.3); transform: scale(1.1); }
        #tutorial-overlay { position: fixed; bottom: 20px; right: 20px; background: #fff; color: #333; padding: 15px; border-radius: 10px; width: 250px; z-index: 5000; box-shadow: 0 5px 15px rgba(0,0,0,0.5); }
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div id="auth-overlay">
        <div class="login-card">
            <h1>🐹 The Nut Vault</h1>
            <input type="text" id="uIn" placeholder="Name"><br>
            <input type="password" id="pIn" placeholder="Code"><br>
            <button onclick="login()">Enter Burrow</button>
        </div>
    </div>

    <div id="tutorial-overlay" class="hidden">
        <h4 id="tut-title">Step 1: Get Cash</h4>
        <p id="tut-text">Mash [SPACE] to spin the wheel and earn NutBucks!</p>
        <button onclick="nextTutorial()">Next</button>
    </div>

    <header>
        <div>💰 <span id="bal">0</span> NB</div>
        <div>❤️ HP: <span id="hp">100</span></div>
        <div>🌊 Wave: <span id="wv">1</span></div>
    </header>

    <div class="dashboard">
        <div class="card"><h3>🏦 Bank</h3><button onclick="bank('bor')">Borrow 100</button><p>Debt: <span id="debt">0</span></p></div>
        <div class="card"><h3>🛒 Store</h3><button onclick="buy('turret', 50)">🌻 Turret (50)</button><div id="pouch"></div></div>
        <div class="card"><h3>🎡 Exercise</h3><div id="wheel" style="font-size:50px">🎡</div></div>
    </div>

    <button onclick="startWave()" style="padding:10px 50px; background:#2ecc71; margin-bottom:10px">🚀 START WAVE</button>
    <canvas id="game" width="640" height="320"></canvas>

<script>
    const USERS = { "Pipsqueak": "carrot123", "Nibbles": "password" };
    let user = "", data = { bal: 100, wave: 1, inv: [], hp: 100, debt: 0, rewards: [] };
    let towers = [], enemies = [], bullets = [], particles = [];
    let selectedIdx = -1, mousePos = {x:0, y:0}, tutorialStep = 0;
    const SIZE = 32, PATH = [{x:0,y:2},{x:1,y:2},{x:2,y:2},{x:3,y:2},{x:4,y:2},{x:5,y:2},{x:5,y:3},{x:5,y:4},{x:6,y:4},{x:7,y:4},{x:8,y:4},{x:9,y:4},{x:10,y:4},{x:10,y:3},{x:10,y:2},{x:10,y:1},{x:11,y:1},{x:12,y:1},{x:13,y:1},{x:14,y:1},{x:15,y:1},{x:15,y:2},{x:15,y:3},{x:15,y:4},{x:16,y:4},{x:17,y:4},{x:18,y:4},{x:19,y:4}];

    // --- AUDIO SYSTEM ---
    const sfx = {
        shoot: new Audio('https://www.soundjay.com'),
        pop: new Audio('https://www.soundjay.com'),
        error: new Audio('https://www.soundjay.com')
    };

    function login() {
        const u = document.getElementById('uIn').value;
        const p = document.getElementById('pIn').value;
        if (USERS[u] === p) {
            user = u;
            document.getElementById('auth-overlay').classList.add('hidden');
            document.getElementById('tutorial-overlay').classList.remove('hidden');
            updateUI(); gameLoop();
        } else { alert("Wrong key!"); }
    }

    function nextTutorial() {
        tutorialStep++;
        const title = document.getElementById('tut-title');
        const text = document.getElementById('tut-text');
        if(tutorialStep === 1) { title.innerText = "Step 2: Shop"; text.innerText = "Buy a Sunflower and click the grass to place it."; }
        else if(tutorialStep === 2) { title.innerText = "Step 3: Defend"; text.innerText = "Launch the wave and don't let them reach the end!"; }
        else document.getElementById('tutorial-overlay').classList.add('hidden');
    }

    function spawnParticles(x, y, color) {
        for(let i=0; i<8; i++) {
            particles.push({ x, y, vx: (Math.random()-0.5)*4, vy: (Math.random()-0.5)*4, life: 30, color });
        }
    }

    function buy(t, c) { 
        if (data.bal >= c) { data.bal -= c; data.inv.push(t); updateUI(); } 
        else { sfx.error.play(); } 
    }

    function bank(t) { if(t==='bor') { data.bal+=100; data.debt+=150; updateUI(); } }

    function updateUI() {
        document.getElementById('bal').innerText = Math.floor(data.bal);
        document.getElementById('hp').innerText = data.hp;
        document.getElementById('wv').innerText = data.wave;
        const pouch = document.getElementById('pouch'); 
        pouch.innerHTML = "";
        data.inv.forEach((it, i) => {
            let b = document.createElement('div');
            b.className = `inv-slot ${selectedIdx === i ? 'selected' : ''}`;
            b.innerHTML = (it === 'turret' ? "🌻" : "🏹");
            b.onclick = () => { selectedIdx = i; updateUI(); };
            pouch.appendChild(b);
        });
    }

    window.addEventListener('keydown', (e) => {
        if (e.code === 'Space') { 
            data.bal += 1; updateUI(); 
            document.getElementById('wheel').style.transform = `rotate(${Math.random()*360}deg)`;
        }
    });

    const canvas = document.getElementById('game'), ctx = canvas.getContext('2d');
    canvas.onclick = (e) => {
        const r = canvas.getBoundingClientRect();
        const tx = Math.floor((e.clientX - r.left)/SIZE), ty = Math.floor((e.clientY - r.top)/SIZE);
        if (selectedIdx !== -1) {
            towers.push({ x: tx*SIZE, y: ty*SIZE, type: data.inv[selectedIdx], cd: 0, range: 120 });
            data.inv.splice(selectedIdx, 1); selectedIdx = -1; updateUI();
        }
    };

    function startWave() {
        let count = 5 + data.wave;
        let t = setInterval(() => {
            enemies.push({ pi: 0, x: PATH[0].x*SIZE, y: PATH[0].y*SIZE, hp: 50, spd: 1.5, icon: "🐁" });
            if (--count <= 0) clearInterval(t);
        }, 800);
    }

    function gameLoop() {
        ctx.fillStyle = "#2d5a27"; ctx.fillRect(0,0,640,320);
        ctx.fillStyle = "#d4a373"; PATH.forEach(p => ctx.fillRect(p.x*SIZE, p.y*SIZE, SIZE, SIZE));

        particles.forEach((p, i) => {
            p.x += p.vx; p.y += p.vy; p.life--;
            ctx.fillStyle = p.color; ctx.fillRect(p.x, p.y, 4, 4);
            if(p.life <= 0) particles.splice(i, 1);
        });

        towers.forEach(t => {
            ctx.fillText(t.type === 'turret' ? "🌻" : "🏹", t.x+4, t.y+24);
            enemies.forEach(en => {
                let d = Math.hypot(en.x-t.x, en.y-t.y);
                if (d < t.range && Date.now() - t.cd > 800) {
                    sfx.shoot.play();
                    en.hp -= 20; t.cd = Date.now();
                    bullets.push({x: t.x+16, y: t.y+16, tx: en.x+16, ty: en.y+16, life: 5});
                }
            });
        });

        enemies.forEach((en, i) => {
            let tg = PATH[en.pi + 1];
            if (tg) {
                let tx = tg.x*SIZE, ty = tg.y*SIZE;
                en.x += (tx > en.x ? en.spd : tx < en.x ? -en.spd : 0);
                en.y += (ty > en.y ? en.spd : ty < en.y ? -en.spd : 0);
                if (Math.abs(en.x-tx)<5 && Math.abs(en.y-ty)<5) en.pi++;
            } else { data.hp -= 10; enemies.splice(i, 1); updateUI(); }
            ctx.fillText(en.icon, en.x, en.y+24);
            if (en.hp <= 0) { 
                sfx.pop.play();
                spawnParticles(en.x, en.y, "yellow");
                data.bal += 20; enemies.splice(i, 1); updateUI(); 
            }
        });

        bullets.forEach((b, i) => {
            ctx.strokeStyle = "white"; ctx.beginPath(); ctx.moveTo(b.x, b.y); ctx.lineTo(b.tx, b.ty); ctx.stroke();
            if(--b.life <= 0) bullets.splice(i, 1);
        });

        requestAnimationFrame(gameLoop);
    }
</script>
</body>
</html>
